<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>酒店列表</title>
    <style>body{background:#f7f8fa;padding:20px}.card{background:#fff;padding:15px;border-radius:15px;margin-bottom:15px}</style>
</head>
<body>
    <h2 id="title"></h2>
    <div id="list"></div>
    <script>
        const region = new URLSearchParams(window.location.search).get('r');
        document.getElementById('title').innerText = region + " 精選酒店";
        const hotels = [{n: region + " 萬豪酒店", p: 1500}, {n: region + " 希爾頓酒店", p: 1200}];
        document.getElementById('list').innerHTML = hotels.map(h => `
            <div class="card">
                <h3>${h.n}</h3>
                <p>價格：¥${h.p} / 晚</p>
                <button onclick="location.href='hotel-detail.html?n=${encodeURIComponent(h.n)}&p=${h.p}'">立即預訂</button>
            </div>
        `).join('');
    </script>
</body>
</html>
